<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_policy_tree" model="ir.ui.view">
        <field name="name">esg.policy.tree</field>
        <field name="model">esg.policy</field>
        <field name="arch" type="xml">
            <tree string="Policies">
                <field name="reference"/>
                <field name="name"/>
                <field name="version"/>
                <field name="category"/>
                <field name="publish_date"/>
                <field name="compliance_rate" widget="progressbar"/>
                <field name="state" widget="badge" decoration-info="state == 'review'" decoration-success="state == 'active'" decoration-muted="state == 'archived'"/>
            </tree>
        </field>
    </record>

    <record id="view_esg_policy_form" model="ir.ui.view">
        <field name="name">esg.policy.form</field>
        <field name="model">esg.policy</field>
        <field name="arch" type="xml">
            <form string="Policy">
                <header>
                    <button name="action_review" type="object" string="Submit for Review" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_activate" type="object" string="Activate" class="oe_highlight" groups="ecosphere_base.group_esg_manager" invisible="state != 'review'"/>
                    <button name="action_archive" type="object" string="Archive" invisible="state not in ('active', 'review')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,active"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="Policy Title"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="version"/>
                            <field name="category"/>
                            <field name="publish_date"/>
                        </group>
                        <group>
                            <field name="document_url" widget="url"/>
                            <field name="require_acknowledgement"/>
                            <field name="compliance_rate" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Acknowledgements" name="acknowledgements" invisible="require_acknowledgement == False">
                            <field name="acknowledgement_ids">
                                <tree editable="bottom" create="0">
                                    <field name="employee_id"/>
                                    <field name="deadline"/>
                                    <field name="state"/>
                                    <field name="is_overdue" widget="boolean_toggle"/>
                                    <button name="action_acknowledge" type="object" string="Acknowledge" icon="fa-check" invisible="state != 'pending'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_esg_policy" model="ir.actions.act_window">
        <field name="name">Policies</field>
        <field name="res_model">esg.policy</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
