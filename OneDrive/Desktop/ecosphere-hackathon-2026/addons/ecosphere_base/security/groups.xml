<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ESG Category -->
        <record id="module_category_esg" model="ir.module.category">
            <field name="name">ESG Management</field>
            <field name="description">Helps you manage your Environmental, Social, and Governance goals.</field>
            <field name="sequence">10</field>
        </record>

        <!-- ESG Employee -->
        <record id="group_esg_employee" model="res.groups">
            <field name="name">ESG Employee</field>
            <field name="category_id" ref="module_category_esg"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Basic access to view ESG scoreboards, participate in challenges, and acknowledge policies.</field>
        </record>

        <!-- Department Head -->
        <record id="group_esg_dept_head" model="res.groups">
            <field name="name">Department Head</field>
            <field name="category_id" ref="module_category_esg"/>
            <field name="implied_ids" eval="[(4, ref('group_esg_employee'))]"/>
            <field name="comment">Can manage department goals and submit carbon transactions.</field>
        </record>

        <!-- ESG Manager (Admin) -->
        <record id="group_esg_manager" model="res.groups">
            <field name="name">ESG Manager</field>
            <field name="category_id" ref="module_category_esg"/>
            <field name="implied_ids" eval="[(4, ref('group_esg_dept_head'))]"/>
            <field name="comment">Full access to all ESG modules, configuration, and reporting.</field>
        </record>
    </data>
</odoo>
