<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_esg_department_tree" model="ir.ui.view">
        <field name="name">esg.department.tree</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <tree string="ESG Departments" default_order="esg_score desc">
                <field name="name"/>
                <field name="manager_id"/>
                <field name="employee_count"/>
                <field name="esg_score" widget="progressbar"/>
                <field name="carbon_progress" widget="progressbar"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_esg_department_form" model="ir.ui.view">
        <field name="name">esg.department.form</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <form string="ESG Department">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Department Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="manager_id"/>
                            <field name="hr_department_id"/>
                            <field name="employee_count"/>
                        </group>
                        <group>
                            <field name="carbon_target"/>
                            <field name="carbon_actual"/>
                            <field name="carbon_progress" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="ESG Scores" name="esg_scores">
                            <group>
                                <group>
                                    <field name="env_score" widget="progressbar"/>
                                    <field name="social_score" widget="progressbar"/>
                                    <field name="gov_score" widget="progressbar"/>
                                </group>
                                <group>
                                    <field name="esg_score" widget="progressbar"/>
                                    <field name="esg_rank"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_esg_department_kanban" model="ir.ui.view">
        <field name="name">esg.department.kanban</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <kanban default_order="esg_score desc">
                <field name="name"/>
                <field name="manager_id"/>
                <field name="esg_score"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click rounded-lg shadow-sm">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body mt-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <span>ESG Score:</span>
                                    <strong><field name="esg_score"/>/100</strong>
                                </div>
                                <field name="esg_score" widget="progressbar"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
