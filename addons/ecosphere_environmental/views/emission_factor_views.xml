<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_emission_factor_tree" model="ir.ui.view">
        <field name="name">esg.emission.factor.tree</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <tree string="Emission Factors">
                <field name="name"/>
                <field name="category"/>
                <field name="scope"/>
                <field name="factor"/>
                <field name="unit"/>
                <field name="source"/>
            </tree>
        </field>
    </record>

    <record id="view_esg_emission_factor_form" model="ir.ui.view">
        <field name="name">esg.emission.factor.form</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <form string="Emission Factor">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Grid Electricity"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="scope"/>
                        </group>
                        <group>
                            <field name="factor"/>
                            <field name="unit"/>
                            <field name="source"/>
                            <field name="year"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_emission_factor" model="ir.actions.act_window">
        <field name="name">Emission Factors</field>
        <field name="res_model">esg.emission.factor</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
