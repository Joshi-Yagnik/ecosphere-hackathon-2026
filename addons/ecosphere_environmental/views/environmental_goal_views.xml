<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_environmental_goal_tree" model="ir.ui.view">
        <field name="name">esg.environmental.goal.tree</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <tree string="Environmental Goals">
                <field name="reference"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="deadline"/>
                <field name="progress" widget="progressbar"/>
                <field name="state" widget="badge" decoration-info="state == 'in_progress'" decoration-success="state == 'achieved'" decoration-muted="state == 'abandoned'"/>
                <field name="is_overdue" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_esg_environmental_goal_form" model="ir.ui.view">
        <field name="name">esg.environmental.goal.form</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <form string="Environmental Goal">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="not_started,in_progress,achieved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="e.g. Reduce paper usage by 50%"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="department_id"/>
                            <field name="deadline"/>
                            <field name="priority"/>
                        </group>
                        <group>
                            <field name="progress" widget="percentpie"/>
                            <field name="is_overdue" invisible="1"/>
                            <div invisible="is_overdue == False" class="alert alert-danger" role="alert">
                                This goal is overdue!
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Action plan..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_esg_environmental_goal" model="ir.actions.act_window">
        <field name="name">Environmental Goals</field>
        <field name="res_model">esg.environmental.goal</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
