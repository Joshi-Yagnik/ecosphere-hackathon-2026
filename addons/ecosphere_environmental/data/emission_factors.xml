<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ef_electricity_grid" model="esg.emission.factor">
            <field name="name">Grid Electricity (US Average)</field>
            <field name="category">electricity</field>
            <field name="scope">scope2</field>
            <field name="unit">kWh</field>
            <field name="factor">0.385</field>
            <field name="source">EPA eGRID 2024</field>
            <field name="year">2024</field>
        </record>
        
        <record id="ef_fuel_diesel" model="esg.emission.factor">
            <field name="name">Diesel Fuel (Stationary)</field>
            <field name="category">fuel</field>
            <field name="scope">scope1</field>
            <field name="unit">Liters</field>
            <field name="factor">2.68</field>
            <field name="source">DEFRA 2024</field>
            <field name="year">2024</field>
        </record>

        <record id="ef_travel_flight_short" model="esg.emission.factor">
            <field name="name">Short Haul Flight (per pax km)</field>
            <field name="category">travel</field>
            <field name="scope">scope3</field>
            <field name="unit">km</field>
            <field name="factor">0.156</field>
            <field name="source">DEFRA 2024</field>
            <field name="year">2024</field>
        </record>

        <record id="ef_waste_landfill" model="esg.emission.factor">
            <field name="name">Commercial Waste to Landfill</field>
            <field name="category">waste</field>
            <field name="scope">scope3</field>
            <field name="unit">kg</field>
            <field name="factor">0.45</field>
            <field name="source">EPA WARM</field>
            <field name="year">2023</field>
        </record>
    </data>
</odoo>
