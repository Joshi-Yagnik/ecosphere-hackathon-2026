<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_esg_carbon_transaction" model="ir.sequence">
            <field name="name">ESG Carbon Transaction</field>
            <field name="code">ecosphere.env.ct</field>
            <field name="prefix">CT-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_esg_environmental_goal" model="ir.sequence">
            <field name="name">ESG Environmental Goal</field>
            <field name="code">ecosphere.env.goal</field>
            <field name="prefix">EG-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
