<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="badge_eco_warrior" model="esg.badge">
            <field name="name">Eco Warrior</field>
            <field name="icon">🌍</field>
            <field name="description">Awarded for participating in 5 environmental initiatives.</field>
            <field name="xp_bonus">500</field>
        </record>

        <record id="badge_carbon_neutral" model="esg.badge">
            <field name="name">Carbon Neutral Hero</field>
            <field name="icon">🌱</field>
            <field name="description">Awarded to departments that meet their carbon target.</field>
            <field name="xp_bonus">1000</field>
        </record>
        
        <record id="badge_community_champion" model="esg.badge">
            <field name="name">Community Champion</field>
            <field name="icon">🤝</field>
            <field name="description">Awarded for logging 50+ CSR volunteer hours.</field>
            <field name="xp_bonus">750</field>
        </record>
    </data>
</odoo>
