<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_badge_tree" model="ir.ui.view">
        <field name="name">esg.badge.tree</field>
        <field name="model">esg.badge</field>
        <field name="arch" type="xml">
            <tree string="Badges">
                <field name="icon"/>
                <field name="name"/>
                <field name="xp_bonus"/>
            </tree>
        </field>
    </record>

    <record id="view_esg_badge_form" model="ir.ui.view">
        <field name="name">esg.badge.form</field>
        <field name="model">esg.badge</field>
        <field name="arch" type="xml">
            <form string="Badge">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="icon" class="oe_inline" placeholder="🏅"/>
                            <field name="name" class="oe_inline" placeholder="Badge Name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="xp_bonus"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_badge" model="ir.actions.act_window">
        <field name="name">Badges</field>
        <field name="res_model">esg.badge</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
