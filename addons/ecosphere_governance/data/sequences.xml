<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_esg_policy" model="ir.sequence">
            <field name="name">ESG Policy</field>
            <field name="code">ecosphere.gov.pol</field>
            <field name="prefix">POL-%(year)s-</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <record id="seq_esg_audit" model="ir.sequence">
            <field name="name">ESG Audit</field>
            <field name="code">ecosphere.gov.audit</field>
            <field name="prefix">AUD-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_esg_compliance_issue" model="ir.sequence">
            <field name="name">ESG Compliance Issue</field>
            <field name="code">ecosphere.gov.issue</field>
            <field name="prefix">ISSUE-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
